# Shopify Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_PASSWORD=your_api_password_here
SHOPIFY_SHOP_NAME=your_store.myshopify.com

# Dixa Configuration
DIXA_API_TOKEN=your_dixa_token_here
